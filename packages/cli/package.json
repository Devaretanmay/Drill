{
  "name": "drill-log",
  "version": "1.0.3",
  "type": "module",
  "description": "AI-powered log diagnosis CLI — severity triage, severity exit codes, git diff context, PII redaction, streaming output",
  "bin": {
    "drill": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/types.d.ts",
  "files": [
    "dist/index.js"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test --ext .ts",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Devaretanmay/Drill"
  },
  "keywords": [
    "cli",
    "debugging",
    "logs",
    "ai",
    "devops",
    "diagnosis",
    "incident-response"
  ],
  "license": "BUSL-1.1",
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "commander": "^12.1.0",
    "conf": "^13.0.0",
    "eventsource-parser": "^3.0.0",
    "glob": "^11.0.0",
    "ora": "^8.0.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^9.0.0",
    "msw": "^2.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
