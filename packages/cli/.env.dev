# Drill CLI - Development Environment Variables
# Copy this file to .env and fill in your API keys
# DO NOT commit .env to version control

# MiniMax API Key (Primary)
DRILL_API_KEY=placeholder_add_key_before_phase2

# API URLs (defaults shown)
DRILL_API_URL=https://api.minimax.io/v1
DRILL_FALLBACK_URL=https://api.together.xyz/v1

# Together AI Key (Fallback)
DRILL_FALLBACK_KEY=placeholder_add_key_before_phase2

# Model names
DRILL_MODEL=MiniMax-M2.5
DRILL_FALLBACK_MODEL=MiniMaxAI/MiniMax-M2.5
